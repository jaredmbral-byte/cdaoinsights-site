# Supabase — get these from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Firecrawl — get from firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# Cron secret — generate a random string to secure cron endpoints
CRON_SECRET=your-random-cron-secret-here
